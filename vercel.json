{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/create-checkout-session", "dest": "/api/server" },
    { "src": "/webhook", "dest": "/api/server" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
